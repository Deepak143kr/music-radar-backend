{
  "expo": {
    "name": "Music Radar",
    "slug": "music-radar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.deepak143kr.musicradar",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deepak143kr.musicradar",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Music Radar needs your microphone to identify nearby music."
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Music Radar needs microphone access to identify music playing around you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f172a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6e2ab83b-db0f-47ea-b5f9-570f5afb216a"
      }
    }
  }
}
